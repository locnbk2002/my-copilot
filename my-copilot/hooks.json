{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "python3 scripts/scout-block.py",
        "powershell": "python scripts/scout-block.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/privacy-block.py",
        "powershell": "python scripts/privacy-block.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/log-subagent-launch.py",
        "powershell": "python scripts/log-subagent-launch.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/comment-checker.py",
        "powershell": "python scripts/comment-checker.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/todo-enforcer.py",
        "powershell": "python scripts/todo-enforcer.py",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "python3 scripts/usage-context-awareness.py",
        "powershell": "python scripts/usage-context-awareness.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/tool-tracker.py",
        "powershell": "python scripts/tool-tracker.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/log-subagent-complete.py",
        "powershell": "python scripts/log-subagent-complete.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/edit-validator.py",
        "powershell": "python scripts/edit-validator.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/agent-babysitter.py",
        "powershell": "python scripts/agent-babysitter.py",
        "cwd": ".",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "python3 scripts/auto-compact-reminder.py",
        "powershell": "python scripts/auto-compact-reminder.py",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "python3 scripts/session-logger.py",
        "powershell": "python scripts/session-logger.py",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python3 scripts/session-logger.py",
        "powershell": "python scripts/session-logger.py",
        "cwd": ".",
        "timeoutSec": 5
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "python3 scripts/error-logger.py",
        "powershell": "python scripts/error-logger.py",
        "cwd": ".",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "python3 scripts/context-recovery.py",
        "powershell": "python scripts/context-recovery.py",
        "cwd": ".",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "python3 scripts/model-fallback.py",
        "powershell": "python scripts/model-fallback.py",
        "cwd": ".",
        "timeoutSec": 10
      }
    ]
  }
}
